{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://knowledgeislands.org/schemas/knowledge-package/1.0.0/knowledge-package.schema.json",
  "title": "Knowledge Package Manifest",
  "description": "Normative machine-readable schema for a Knowledge Islands Knowledge Package manifest, implementing KIS-0001 v1.0.0. The $id is a stable identifier, not a promise of a resolvable URL.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "specVersion",
    "id",
    "uuid",
    "name",
    "version",
    "lifecycle",
    "classification",
    "created",
    "owners",
    "digests"
  ],
  "properties": {
    "specVersion": {
      "description": "Version of KIS-0001 this package conforms to.",
      "$ref": "#/$defs/semver"
    },
    "id": {
      "description": "Package identifier: ki:pkg:<namespace>/<slug>@<semver>.",
      "type": "string",
      "pattern": "^ki:pkg:[a-z0-9][a-z0-9-]*/[a-z0-9][a-z0-9-]*@\\d+\\.\\d+\\.\\d+$"
    },
    "uuid": {
      "description": "UUID v4, stable across all versions of the same package.",
      "type": "string",
      "format": "uuid"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "description": "Package version; MUST match the @<semver> segment of id.",
      "$ref": "#/$defs/semver"
    },
    "lifecycle": {
      "$ref": "#/$defs/lifecycleState"
    },
    "classification": {
      "$ref": "#/$defs/classification"
    },
    "created": {
      "type": "string",
      "format": "date-time"
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Party"
      }
    },
    "digests": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "executive"
      ],
      "properties": {
        "executive": {
          "$ref": "#/$defs/Digest"
        },
        "technical": {
          "$ref": "#/$defs/Digest"
        }
      }
    },
    "description": {
      "type": "string"
    },
    "updated": {
      "type": "string",
      "format": "date-time"
    },
    "conformanceLevel": {
      "type": "string",
      "enum": [
        "minimal",
        "standard",
        "extended"
      ]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decisions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Decision"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "terminology": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Term"
      }
    },
    "openQuestions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Task"
      }
    },
    "deliverables": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Deliverable"
      }
    },
    "references": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Reference"
      }
    },
    "provenance": {
      "$ref": "#/$defs/Provenance"
    },
    "governance": {
      "$ref": "#/$defs/Governance"
    },
    "handover": {
      "$ref": "#/$defs/Handover"
    },
    "history": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/HistoryEvent"
      }
    },
    "related": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Related"
      }
    },
    "artefacts": {
      "description": "Map of artefact-kind to a relative path within the package.",
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "extensions": {
      "description": "Free-form, ideally namespaced extension data. Consumers MUST ignore extensions they do not understand.",
      "type": "object"
    }
  },
  "$defs": {
    "semver": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "lifecycleState": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "paused",
        "handover",
        "completed",
        "archived",
        "superseded"
      ]
    },
    "classification": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "confidential",
        "privileged"
      ]
    },
    "Party": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "organisation"
          ]
        },
        "role": {
          "type": "string"
        },
        "contact": {
          "type": "string"
        }
      }
    },
    "Digest": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "anyOf": [
        {
          "required": [
            "summary"
          ]
        },
        {
          "required": [
            "path"
          ]
        }
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "description": "Relative path to a Markdown artefact.",
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Term": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "term",
        "definition"
      ],
      "properties": {
        "term": {
          "type": "string"
        },
        "definition": {
          "type": "string"
        }
      }
    },
    "Task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "todo",
            "in_progress",
            "blocked",
            "done",
            "cancelled"
          ]
        },
        "description": {
          "type": "string"
        },
        "assignee": {
          "$ref": "#/$defs/Party"
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deliverables": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Deliverable": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "status": {
          "type": "string"
        }
      }
    },
    "Decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "accepted",
            "superseded"
          ]
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "rationale": {
          "type": "string"
        },
        "supersedes": {
          "type": "string"
        }
      }
    },
    "Reference": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "title": {
          "type": "string"
        },
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "path": {
          "type": "string"
        },
        "note": {
          "type": "string"
        }
      }
    },
    "Provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "createdBy"
      ],
      "properties": {
        "createdBy": {
          "$ref": "#/$defs/Party"
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Reference"
          }
        },
        "method": {
          "type": "string"
        }
      }
    },
    "HistoryEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "timestamp",
        "actor",
        "action"
      ],
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "actor": {
          "$ref": "#/$defs/Party"
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "note": {
          "type": "string"
        }
      }
    },
    "Handover": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "instructions": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "context": {
          "type": "string"
        },
        "resumePoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Governance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "steward": {
          "$ref": "#/$defs/Party"
        },
        "reviewers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Party"
          }
        },
        "promotionPolicy": {
          "type": "string"
        },
        "retention": {
          "type": "string"
        }
      }
    },
    "Related": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "relationship"
      ],
      "anyOf": [
        {
          "required": [
            "id"
          ]
        },
        {
          "required": [
            "uri"
          ]
        }
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "uri": {
          "type": "string",
          "format": "uri"
        },
        "relationship": {
          "type": "string",
          "enum": [
            "supersedes",
            "supersededBy",
            "dependsOn",
            "derivedFrom",
            "relatesTo",
            "partOf",
            "promotedTo"
          ]
        },
        "note": {
          "type": "string"
        }
      }
    }
  }
}
